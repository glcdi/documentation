{
  "@context": {
    "@vocab": "https://w3id.org/edc/v0.0.1/ns/",
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "glcdi": "https://w3id.org/glcdi/v0.1.0/ns/"
  },
  "@id": "glcdi:access:regenerative-producers",
  "@type": "PolicyDefinition",
  "policy": {
    "@context": "http://www.w3.org/ns/odrl.jsonld",
    "@type": "Set",
    "permission": [
      {
        "action": "use",
        "constraint": [
          {
            "leftOperand": "glcdi:membership",
            "operator": "eq",
            "rightOperand": "active"
          },
          {
            "leftOperand": "glcdi:participantType",
            "operator": "eq",
            "rightOperand": "producer"
          },
          {
            "leftOperand": "glcdi:certificationStatus",
            "operator": "isAnyOf",
            "rightOperand": ["organic-certified", "regenerative-verified", "transitioning-organic"]
          }
        ]
      }
    ]
  }
}
