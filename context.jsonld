    },
    "contributionStatus": {
      "@id": "glcdi:contributionStatus",
      "@type": "@id"
    },
    "membership": {
      "@id": "glcdi:membership",
      "@type": "xsd:string"
    },
    "organisation": {
      "@id": "glcdi:organisation",
      "@type": "xsd:string"
    },
    "roles": {
      "@id": "glcdi:roles",
      "@container": "@set"
    },
    "accessOutcome": {
      "@id": "glcdi:accessOutcome",
      "@type": "@id"
    },
    "shareBack": {
      "@id": "glcdi:shareBack",
      "@type": "@id"
    },
    "producer": "glcdi:producer",
    "researcher": "glcdi:researcher",
    "data-steward": "glcdi:data-steward",
    "conservation-org": "glcdi:conservation-org",
    "technology-provider": "glcdi:technology-provider",
    "corporate": "glcdi:corporate",
    "certification-body": "glcdi:certification-body",
    "supply-chain-partner": "glcdi:supply-chain-partner",
    "funder": "glcdi:funder",
    "organic-certified": "glcdi:organic-certified",
    "regenerative-verified": "glcdi:regenerative-verified",
    "transitioning-organic": "glcdi:transitioning-organic",
    "conventional": "glcdi:conventional",
    "not-applicable": "glcdi:not-applicable",
    "contributing": "glcdi:contributing",
    "observer": "glcdi:observer",
    "InternalAnalysis": "glcdi:InternalAnalysis",
    "ScientificResearch": "glcdi:ScientificResearch",
    "AgronomicModelTraining": "glcdi:AgronomicModelTraining",
    "EcosystemModelCalibration": "glcdi:EcosystemModelCalibration",
    "RegionalBenchmarking": "glcdi:RegionalBenchmarking",
    "EducationalUse": "glcdi:EducationalUse",
    "ConservationPlanning": "glcdi:ConservationPlanning",
    "Scope3Reporting": "glcdi:Scope3Reporting",
    "ESGCompliance": "glcdi:ESGCompliance",
    "CertificationVerification": "glcdi:CertificationVerification",
    "ModelOutput": "glcdi:ModelOutput",
    "granted": "glcdi:granted",
    "denied": "glcdi:denied",
    "purpose": {
      "@id": "odrl:purpose",
      "@type": "@vocab"
    },
    "elapsedTime": {
      "@id": "odrl:elapsedTime",
      "@type": "xsd:duration"
    },
    "payAmount": {
      "@id": "odrl:payAmount",
      "@type": "xsd:decimal"
    },
    "paymentStatus": {
      "@id": "odrl:paymentStatus",
      "@type": "@id"
    },
    "dateTime": {
      "@id": "odrl:dateTime",
      "@type": "xsd:dateTime"
    }
  }
