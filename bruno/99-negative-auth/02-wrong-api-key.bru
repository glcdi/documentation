meta {
  name: Management API call with wrong X-Api-Key — expect 401
  type: http
  seq: 2
}

get {
  url: {{caney_fork_host}}/management/v3/assets
  body: none
  auth: none
}

# Wrong key — should be rejected by the connector's tokenbased auth
# (web.http.management.auth.type=tokenbased) before any handler runs.
headers {
  Accept: application/json
  X-Api-Key: deadbeef
}

tests {
  test("status is 401", function() {
    expect(res.getStatus()).to.equal(401);
  });
}
