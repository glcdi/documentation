  point_blue_dsp: https://point-blue.glcdi.startinblox.com/protocol
  white_buffalo_dsp: https://white-buffalo.glcdi.startinblox.com/protocol
  demo_dsp: https://demo.glcdi.startinblox.com/protocol
  authority_host: https://authority.glcdi.startinblox.com/auth/realms/glcdi
  caney_fork_participant_id: glcdi-connector-caney-fork
  point_blue_participant_id: glcdi-connector-point-blue
  white_buffalo_participant_id: glcdi-connector-white-buffalo
  demo_participant_id: glcdi-connector-demo
  demo_data_root: https://demo.glcdi.startinblox.com/data
  m1_asset_id: urn:glcdi:asset:caney-fork:grazing-soc-2024
  m1_asset_base_url: https://api.stg.caneyfork.glcdi.startinblox.com/metrics/
  m1_research_asset_base_url: https://api.stg.caneyfork.glcdi.startinblox.com/plots/
  m1_researcher_only_asset_base_url: https://api.stg.caneyfork.glcdi.startinblox.com/farms/
  m1_asset_description: Soil organic carbon Metric records from Caney Fork's /metrics/ container (djangoldp_glcdi baseline), 2024 season — restricted to producers (M1 fixture).
  m1_research_asset_description: Plot-level grazing summary from Caney Fork's /plots/ container (djangoldp_glcdi baseline), aggregated 2024 — open to any active dataspace member (M1 fixture).
  m1_researcher_only_asset_description: Farm-level raw observations from Caney Fork's /farms/ container (djangoldp_glcdi baseline), 2024 — restricted to researcher participants (M1 fixture).
  m1_access_policy_id: producer-only-policy
  m1_contract_policy_id: internal-use-only-policy
  m1_contract_definition_id: caney-fork-grazing-soc-2024-cd
  m1_research_asset_id: urn:glcdi:asset:caney-fork:grazing-summary-2024
  m1_research_access_policy_id: members-policy
  m1_research_contract_definition_id: caney-fork-grazing-summary-2024-cd
  m1_researcher_only_asset_id: urn:glcdi:asset:caney-fork:grazing-raw-observations-2024
  m1_researcher_only_access_policy_id: researcher-only-policy
  m1_researcher_only_contract_definition_id: caney-fork-grazing-raw-observations-2024-cd
  org_display_name: Caney Fork
  farmos_animal_asset_id: urn:glcdi:asset:caney-fork:farmos-animals-2024
  farmos_animal_cd_id: caney-fork-farmos-animals-cd
  farmos_animal_scope: farm_viewer
  farmos_token_url: https://farmos.caney-fork.glcdi.startinblox.com/oauth/token
  farmos_animal_base_url: https://farmos.caney-fork.glcdi.startinblox.com/api/asset/animal
}
