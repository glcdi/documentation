{
  "realm": "glcdi",
  "displayName": "GLCDI Dataspace",
  "enabled": true,
  "loginTheme": "glcdi",
  "sslRequired": "none",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Default user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      },
      {
        "name": "glcdi_member",
        "description": "GLCDI dataspace member (active participant)"
      },
      {
        "name": "glcdi_producer",
        "description": "Producer participant type - regenerative qualification is carried by glcdi_certification_status, not by a separate role"
      },
      {
        "name": "glcdi_researcher",
        "description": "Research institution / NGO"
      },
      {
        "name": "glcdi_non_regulatory",
        "description": "Non-regulatory body"
      },
      {
        "name": "glcdi_non_profit",
        "description": "Non-commercial / non-profit organization"
      },
      {
        "name": "glcdi_corporate_or_supply_chain",
        "description": "Corporate participant / supply-chain actor"
      },
      {
        "name": "glcdi_other",
        "description": "Other participant type (catch-all for onboarding mapping)"
      }
    ],
    "client": {
      "governance": [
        {
          "name": "manage-users",
          "description": "Manage users in the Authority realm"
        }
      ],
      "glcdi-ui": [
        {
          "name": "catalog-viewer",
          "description": "View catalogue entries"
        }
      ]
    }
  },
  "clientScopes": [
    {
      "name": "glcdi-claims",
      "description": "GLCDI custom claims (membership, roles, organization, certification status, contribution status)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "glcdi-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "glcdi_roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "glcdi-membership-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "glcdi_membership",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "glcdi_membership",
            "jsonType.label": "String"
          }
        },
        {
          "name": "glcdi-organization-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "glcdi_organization",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "glcdi_organization",
            "jsonType.label": "String"
          }
        },
        {
          "name": "glcdi-certification-status-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "glcdi_certification_status",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "glcdi_certification_status",
            "jsonType.label": "String"
          }
        },
        {
          "name": "glcdi-contribution-status-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "glcdi_contribution_status",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "glcdi_contribution_status",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
